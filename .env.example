# Bot root environment variables
TOKEN=your_discord_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

# Internal Bot API server (bot-side)
BOT_API_PORT=4000
BOT_API_KEY=local_dashboard_key_123

# Shared SQLite database — ABSOLUTE PATH for Windows
DATABASE_PATH=C:/Users/ADAM/Desktop/Discord-Activity-Intelligence-Bot/data.db

# Student role for automatic roster sync
# Prefer STUDENT_ROLE_IDS (comma-separated) if set; falls back to STUDENT_ROLE_NAME
STUDENT_ROLE_NAME=Student
STUDENT_ROLE_IDS=